{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "contact": {
    "homepage": "https://github.com/KURONAMI333/away-digest",
    "issues":   "https://github.com/KURONAMI333/away-digest/issues",
    "sources":  "https://github.com/KURONAMI333/away-digest"
  },
  "license": "${mod_license}",

  "environment": "*",

